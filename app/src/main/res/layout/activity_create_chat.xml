<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#AAAAAA">

    <!-- Верхняя панель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#AAAAAA"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/back"
            android:contentDescription="Назад" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Написать сообщение"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center" />

        <View
            android:layout_width="24dp"
            android:layout_height="24dp" />

    </LinearLayout>

    <!-- Кнопки создания -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center"
        android:background="@color/white">

        <Button
            android:id="@+id/btnCreateGroup"
            android:layout_height="match_parent"
            android:layout_width="match_parent"
            android:text="Создать группу"
            android:textSize="14sp"
            android:backgroundTint="#9E9E9E" />

        <Button
            android:id="@+id/btnCreateContact"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="Создать контакт"
            android:textSize="14sp"
            android:backgroundTint="#777777" />

        <Button
            android:id="@+id/btnCreateChannel"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="Создать канал"
            android:textSize="14sp"
            android:backgroundTint="#555555" />

    </LinearLayout>

    <!-- Список контактов -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvContacts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="0dp"
        android:clipToPadding="false"
        android:background="@color/white"/>

    <!-- Текст "Нет контактов" -->
    <TextView
        android:id="@+id/tvNoContacts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Нет контактов"
        android:textSize="16sp"
        android:textColor="#757575"
        android:gravity="center"
        android:visibility="gone"
        android:background="@color/white"/>

</LinearLayout>